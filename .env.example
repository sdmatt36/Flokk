# =============================================================================
# Travel App — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# =============================================================================

# DATABASE (Supabase)
# Found in: Supabase dashboard → Project Settings → Database → Connection string
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# AUTH (Clerk)
# Found in: Clerk dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/home"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/onboarding"

# AI (Anthropic)
# Found in: console.anthropic.com → API Keys
ANTHROPIC_API_KEY="sk-ant-..."

# MAPS (Google Cloud)
# Found in: Google Cloud Console → APIs & Services → Credentials
GOOGLE_MAPS_API_KEY="AIza..."

# BACKGROUND JOBS (Inngest)
# Found in: Inngest dashboard → Settings
INNGEST_EVENT_KEY="..."
INNGEST_SIGNING_KEY="..."

# FILE STORAGE (Cloudflare R2)
# Found in: Cloudflare dashboard → R2 → Manage R2 API tokens
CLOUDFLARE_ACCOUNT_ID="..."
CLOUDFLARE_R2_ACCESS_KEY_ID="..."
CLOUDFLARE_R2_SECRET_ACCESS_KEY="..."
CLOUDFLARE_R2_BUCKET_NAME="travelapp-media"

# EMAIL (Resend)
# Found in: resend.com → API Keys
RESEND_API_KEY="re_..."

# ANALYTICS (PostHog)
# Found in: PostHog dashboard → Settings → Project API key
NEXT_PUBLIC_POSTHOG_KEY="phc_..."
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# APP
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# INBOUND EMAIL (CloudMailin)
# Create a target at cloudmailin.com → HTTP POST JSON format
# Point to: https://www.flokktravel.com/api/webhooks/email-inbound
# Set the MX record for trips@flokktravel.com to CloudMailin's servers
CLOUDMAILIN_ADDRESS="trips@flokktravel.com"

# WEBHOOK SECRET
# Set a random secret string here and configure it as a custom header in CloudMailin
# (CloudMailin: Target settings → Custom Headers → X-Webhook-Secret: <value>)
WEBHOOK_SECRET="generate-a-strong-random-secret-here"
# EVENTS — TheSportsDB (Phase A: sports_events only)
# Free tier key is the literal string "123" — no registration required.
# Patreon $3/mo unlocks additional endpoints (not needed for Phase A).
THESPORTSDB_API_KEY="123"
